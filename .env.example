IEEE_INST_NAME=Example University
IEEE_INST_USERNAME=your-campus-account
IEEE_INST_PASSWORD=replace-me-locally
# Optional: path to a local credential file if you do not want to export the variables directly.
# IEEE_CREDENTIAL_FILE=/absolute/path/to/ieee.env
# Optional: host hint for your institutional SSO provider.
# IEEE_SSO_HOST=login.example.edu
